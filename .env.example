# ── 本地开发 ──────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=1
IB_ACCOUNT_ID=your_sub_account_id   # 子账户号，留空则读取所有账户
DB_PATH=ib_viewer.db

# ── Docker 部署 ───────────────────────────
# IB_HOST=ib-gateway   # 容器间通信，用 docker-compose service 名
IB_USERNAME=your_ib_username
IB_PASSWORD=your_ib_password
VNC_PASSWORD=your_vnc_password
